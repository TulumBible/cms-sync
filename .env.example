# Convex deployment that emits /cms-snapshot/* endpoints. Use the
# `.convex.site` host (HTTP actions), NOT `.convex.cloud` (client SDK).
# Example: https://witty-marlin-123.convex.site
CONVEX_SITE_URL=

# Shared secret for the /cms-snapshot/* endpoints. Must match Convex's
# INTERNAL_CMS_KEY env var. Rotate on both sides together:
#   npx convex env set INTERNAL_CMS_KEY <newvalue>
#   # update this secret on GitHub Actions
INTERNAL_CMS_KEY=

# Optional: when set, sync.ts only syncs this one city slug (as defined
# in cities.json) and skips the rest. Used by workflow_dispatch input
# to scope manual syncs. Leave unset to sync every active city.
# SYNC_ONLY_CITY=tulum

# Optional: set to "1" on the draft branch of this repo so the sync
# fetches publishable routes with ?drafts=1 — live projection with
# isDraft flags, not the frozen publishedSnapshot. Leave unset on main
# to emit only published content.
# SYNC_INCLUDE_DRAFTS=1
